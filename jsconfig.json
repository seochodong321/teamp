{
  "compilerOptions": {
    "baseUrl": "src",
    "checkJs": false,
    "allowJs": true,
    "moduleResolution": "bundler",
    "module": "preserve",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
