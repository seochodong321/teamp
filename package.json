{
  "name": "teamp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-sw.mjs && vite",
    "build": "node scripts/gen-sw.mjs && vite build",
    "build:ci": "node scripts/gen-sw.mjs --production && vite build",
    "preview": "vite preview",
    "gen-sw": "node scripts/gen-sw.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,storage --project demo-teamp \"vitest run --config vitest.rules.config.js\"",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "date-fns": "^3.3.1",
    "firebase": "^12.12.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "playwright": "^1.60.0",
    "vite": "^5.1.0",
    "vitest": "^4.1.8"
  }
}
