rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 부트스트랩(루트) 어드민 — 하드코딩 이메일. 항상 어드민이고 승급/강등 권한 보유.
    function isBootstrap() {
      return request.auth != null && request.auth.token.email == 'seobomin524@gmail.com';
    }
    // 어드민 = 부트스트랩 또는 승급된 유저(users.isAdmin == true)
    function isAdmin() {
      return isBootstrap() || (
        request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // ──────────────────────────────────────────────
    // users
    //   읽기: 인증된 모든 유저
    //   생성: 본인 (isAdmin·plan 세팅 불가 — 가입 시 기본값만 허용)
    //   수정: 본인(plan은 student로만 변경 가능, isAdmin 변경 불가) 또는 어드민
    //   삭제: 어드민만
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        !request.resource.data.keys().hasAny(['isAdmin']) &&
        (!request.resource.data.keys().hasAny(['plan']) ||
          request.resource.data.plan == 'free');
      allow update: if (
        request.auth != null &&
        request.auth.uid == userId &&
        // isAdmin 자가승급 차단 + 꽃다발 집계는 서버 함수(aggregateFlowerFeedback)만 — 자가 위조 차단
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isAdmin', 'flowerTagSummary', 'flowerSenderUids', 'flowerSenderCount']) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan']) ||
          request.resource.data.plan == 'student')
      )
      // 부트스트랩만 isAdmin 변경(승급/강등) 가능
      || isBootstrap()
      // 승급된 어드민은 다른 필드(banned·plan 등)는 수정하되 isAdmin은 못 건드림
      || (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // usernames — 닉네임 유일성 (문서ID = 소문자 닉네임)
    //   선점=create(자기 uid로만, 이미 있으면 create 실패 → 중복 불가),
    //   반환=delete(그 닉네임 소유 본인만). update는 막음.
    // ──────────────────────────────────────────────
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ──────────────────────────────────────────────
    // projects
    //   읽기: 멤버이거나 isPublic == true 또는 어드민
    //   생성: 인증된 유저 (자신을 memberIds에 포함 + 본인이 리더)
    //   수정: 리더=전권 / 일반 멤버=권한필드 제외 / 비멤버=본인 합류만 / 어드민
    //   삭제: 리더만 또는 어드민
    //
    //   ⚠️ 권한 필드(leaderId·isPublic·isTutorial·inviteCode)는 리더/어드민만 변경.
    //      일반 멤버가 leaderId를 자기로 바꿔 리더 탈취(→삭제) / isPublic 강제공개 /
    //      isTutorial로 무료 한도 우회하던 권한 상승 경로를 차단한다.
    //   ※ 비멤버 합류(초대 수락·코드 참여)는 "자신을 memberIds에 추가"하는 update이므로
    //      기존 멤버십 검사로는 거부됐다(합류가 사실상 막혀 있던 버그). 아래 isProjectSelfJoin이 복구.
    // ──────────────────────────────────────────────
    match /projects/{projectId} {
      function touchesProjectAuthority() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['leaderId', 'isPublic', 'isTutorial', 'inviteCode']);
      }
      function isProjectSelfJoin() {
        return !(request.auth.uid in resource.data.memberIds) &&
          request.auth.uid in request.resource.data.memberIds &&
          !touchesProjectAuthority();
      }

      allow read: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        resource.data.isPublic == true ||
        isAdmin()
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.leaderId == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null && (
        // 리더: 전권
        request.auth.uid == resource.data.leaderId ||
        // 기존 멤버: 권한 필드는 못 건드림 (협업 데이터만)
        (request.auth.uid in resource.data.memberIds && !touchesProjectAuthority()) ||
        // 비멤버: 본인을 명단에 추가하는 합류만
        isProjectSelfJoin()
      ));
      allow delete: if (request.auth != null &&
        request.auth.uid == resource.data.leaderId) || isAdmin();
    }

    // ──────────────────────────────────────────────
    // 방 접근 검증 헬퍼 — 메시지는 "그 방을 볼 자격이 있는 사람"만.
    //   DM: dmRooms/{roomId}.participants
    //   프로젝트 방: rooms/{roomId} 메타의 projectId → 프로젝트 memberIds
    //   나와의 채팅: 메타에 ownerId 있으면 그 본인만
    //   레거시 fallback: 메타가 아직 없는 옛 방(점진 생성 중) — ⚠️ 전 클라이언트 배포 후 제거
    // ──────────────────────────────────────────────
    function isDmParticipant(roomId) {
      return exists(/databases/$(database)/documents/dmRooms/$(roomId)) &&
        request.auth.uid in get(/databases/$(database)/documents/dmRooms/$(roomId)).data.participants;
    }
    function isRoomMember(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(get(/databases/$(database)/documents/rooms/$(roomId)).data.projectId)).data.memberIds &&
        (!('ownerId' in get(/databases/$(database)/documents/rooms/$(roomId)).data) ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid);
    }
    function isLegacyRoom(roomId) {
      return !exists(/databases/$(database)/documents/dmRooms/$(roomId)) &&
        !exists(/databases/$(database)/documents/rooms/$(roomId));
    }
    function canAccessRoom(roomId) {
      return isDmParticipant(roomId) || isRoomMember(roomId) || isLegacyRoom(roomId) || isAdmin();
    }

    // ──────────────────────────────────────────────
    // rooms/{roomId} — 방 메타 (projectId 필수, ownerId는 나와의채팅 전용)
    //   생성: 그 프로젝트 멤버만. 수정 없음(불변). 삭제: 프로젝트 정리 시 멤버/어드민.
    // ──────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['projectId']) &&
        request.resource.data.keys().hasOnly(['projectId', 'ownerId']) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.memberIds;
      allow delete: if isAdmin() || (request.auth != null && (
        // 프로젝트가 이미 지워진 고아 메타는 정리 허용, 살아있으면 멤버만
        !exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) ||
        request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberIds
      ));

      // ── 메시지 — 방 접근 자격자만. 생성 시 발신자 위조 차단(시스템·봇 제외)
      match /messages/{messageId} {
        allow read: if request.auth != null && canAccessRoom(roomId);
        allow create: if request.auth != null && canAccessRoom(roomId) &&
          (request.resource.data.senderId == request.auth.uid ||
            request.resource.data.senderId in ['system', 'teamp_bot', 'teampbot']);
        allow update, delete: if request.auth != null && canAccessRoom(roomId);
      }
    }

    // ──────────────────────────────────────────────
    // dmRooms
    //   get: 문서가 없을 때(resource==null)도 허용 — 존재 여부 확인 후 생성하는 패턴
    //   list: 본인이 participants에 있는 경우만
    //   create: 자신을 participants에 포함해야 함
    //   update: 참가자만
    // ──────────────────────────────────────────────
    match /dmRooms/{dmRoomId} {
      allow get: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);
      allow list: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
    }

    // ──────────────────────────────────────────────
    // notifications
    //   읽기/삭제: 수신자만
    //   생성: 발신자 본인 검증(fromUserId == 본인 필수) + link는 앱 내부 상대경로만.
    //     - fromUserId 필수화: 사칭·익명 스팸 푸시 차단(구버전 임시 허용 제거).
    //     - link 상대경로 강제: 푸시 클릭 목적지가 외부(https://evil)나 프로토콜상대('//evil')로
    //       빠지는 피싱을 차단. 허용 형태는 '/...' (단, '//'로 시작 불가).
    // ──────────────────────────────────────────────
    match /notifications/{notiId} {
      allow read, delete: if request.auth != null &&
        request.auth.uid == resource.data.targetUserId;
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid &&
        (!('link' in request.resource.data) || (
          request.resource.data.link is string &&
          request.resource.data.link.matches('^/([^/].*)?$')
        ));
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.targetUserId;
    }

    // ──────────────────────────────────────────────
    // projectInvites
    //   읽기: 초대한 사람(inviterId) 또는 초대받은 사람(inviteeId)
    //   생성: 인증된 유저 (초대자 본인)
    //   수정: 초대받은 사람만 (수락/거절)
    // ──────────────────────────────────────────────
    match /projectInvites/{inviteId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.inviteeId ||
        request.auth.uid == resource.data.inviterId
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.inviterId;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.inviteeId;
    }

    // ──────────────────────────────────────────────
    // matchPosts
    //   읽기: 인증된 모든 유저
    //   생성: 인증된 유저 (leaderId == 본인)
    //   수정:
    //     - 리더 또는 어드민
    //     - 일반 유저: applicants 필드만 추가 가능 (지원하기)
    //   삭제: 리더만 또는 어드민
    // ──────────────────────────────────────────────
    match /matchPosts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
        request.resource.data.leaderId == request.auth.uid;

      allow update: if isAdmin() || (request.auth != null && (
        // 리더는 모든 필드 수정 가능
        resource.data.leaderId == request.auth.uid ||
        // 일반 유저는 applicants 필드만 변경 가능 (지원하기)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicants']) &&
          // 항목이 하나 추가된 경우만 허용 (arrayUnion)
          request.resource.data.applicants.size() == resource.data.applicants.size() + 1 &&
          // 추가된 항목의 userId가 본인이어야 함
          request.resource.data.applicants[request.resource.data.applicants.size() - 1].userId == request.auth.uid
        )
      ));

      allow delete: if (request.auth != null &&
        request.auth.uid == resource.data.leaderId) || isAdmin();
    }

    // ──────────────────────────────────────────────
    // wrapups
    //   읽기: 그 랩업의 멤버만(+어드민) — 피드백 원문은 팀 내부 기록.
    //         공개 프로필 꽃다발은 users.flowerTagSummary 캐시로 충분(서버 함수가 집계).
    //   생성: 프로젝트 리더 / 수정: 멤버 (회고·피드백)
    // ──────────────────────────────────────────────
    match /wrapups/{wrapupId} {
      allow read: if isAdmin() || (request.auth != null &&
        request.auth.uid in resource.data.memberIds);
      allow create: if request.auth != null &&
        request.resource.data.leaderId == request.auth.uid;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.memberIds;
    }

    // ──────────────────────────────────────────────
    // notes (쪽지)
    //   읽기/수정: participants에 포함된 유저만
    //   생성: 인증된 유저 (자신을 participants에 포함해야 함)
    // ──────────────────────────────────────────────
    match /notes/{noteId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if (request.auth != null &&
        request.auth.uid in request.resource.data.participants) || isAdmin();
    }

    // ──────────────────────────────────────────────
    // reports
    //   생성: 로그인된 유저 — reporterId 본인 검증 + 사유·상세 길이 제한
    //   읽기/수정/삭제: 어드민만
    // ──────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if request.auth != null &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reason in ['illegal', 'spam', 'false', 'hate', 'other'] &&
        request.resource.data.detail is string &&
        request.resource.data.detail.size() <= 300;
      allow read, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // adminLogs — 어드민 활동 감사 로그 (블락·탈퇴·요금제 변경)
    //   읽기·생성: 어드민만. 수정·삭제 없음(append-only로 무결성).
    // ──────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
    }

  }
}
